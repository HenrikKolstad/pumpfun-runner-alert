# Copy to .env and fill in. The only required value is the Discord webhook.
# In Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=

# Alert rule (defaults match "runs to $1M in under 1 hour")
MCAP_TARGET_USD=1000000        # fire when market cap >= this
MAX_AGE_MIN=60                 # ...and the token is younger than this many minutes
MIN_LIQUIDITY_USD=20000        # ignore thin pools where "$1M" is a price glitch

# Tiered polling
WARM_MCAP_USD=100000           # a token past this is "hot" and fast-polled
HOT_INTERVAL_SEC=6             # how often hot (climbing) tokens are checked
COLD_INTERVAL_SEC=25           # how often the full token set is swept
LOG_LEVEL=info                 # info | debug
